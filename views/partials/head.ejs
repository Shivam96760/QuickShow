<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#09090B" />
<title><%= typeof title !== 'undefined' ? title : 'QuickShow' %></title>
<meta name="description" content="QuickShow — book movie tickets in seconds. Browse trending films, pick the best seat, and enjoy the show." />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          background: "#09090B",
          surface: "#111113",
          card: "#17171A",
          primary: {
            DEFAULT: "#F84565",
            hover: "#E0354F",
            soft: "rgba(248, 69, 101, 0.12)",
          },
          border: "#26262A",
          muted: "#8A8A93",
        },
        fontFamily: {
          sans: ["Inter", "ui-sans-serif", "system-ui"],
          display: ["Sora", "Inter", "ui-sans-serif"],
        },
        boxShadow: {
          glow: "0 20px 60px -20px rgba(248, 69, 101, 0.45)",
        },
      },
    },
  }
</script>

<link rel="stylesheet" href="/css/styles.css" />
<link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
