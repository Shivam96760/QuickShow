<div class="lg:flex">
  <%- include('../../partials/admin-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <header class="sticky top-0 z-30 bg-background/90 backdrop-blur border-b border-border">
      <div class="flex items-center justify-between px-4 sm:px-8 h-16">
        <h1 class="font-display text-xl font-semibold text-white">List bookings</h1>
        <div class="w-8 h-8 rounded-full bg-card border border-border flex items-center justify-center text-xs font-semibold text-white">A</div>
      </div>
    </header>

    <main class="p-4 sm:p-8">
      <div class="mb-6 flex items-end justify-between flex-wrap gap-4">
        <div>
          <h2 class="font-display text-2xl font-bold text-white">All bookings</h2>
          <p class="mt-1 text-sm text-muted">Track every booking across QuickShow.</p>
        </div>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          <input
            type="search"
            placeholder="Search bookings..."
            class="pl-9 pr-4 py-2.5 w-full sm:w-64 bg-card border border-border rounded-lg text-sm text-white placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary"
          />
        </div>
      </div>

      <div class="bg-card border border-border rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs font-medium uppercase tracking-wider text-muted bg-surface/60">
                <th class="px-5 py-3">Booking</th>
                <th class="px-5 py-3">User</th>
                <th class="px-5 py-3">Movie</th>
                <th class="px-5 py-3">Seats</th>
                <th class="px-5 py-3">Amount</th>
                <th class="px-5 py-3">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <% bookings.forEach(b => { %>
                <tr class="hover:bg-surface/40 transition-colors">
                  <td class="px-5 py-4 font-mono text-xs text-white"><%= b.id %></td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 rounded-full bg-primary-soft border border-primary/30 flex items-center justify-center text-xs font-semibold text-primary">
                        <%= b.user.charAt(0) %>
                      </div>
                      <div>
                        <p class="font-medium text-white"><%= b.user %></p>
                        <p class="text-xs text-muted"><%= b.date %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3 min-w-0">
                      <img src="<%= b.movie.poster %>" alt="" class="w-8 h-10 rounded object-cover border border-border" />
                      <p class="font-medium text-white truncate max-w-[180px]"><%= b.movie.title %></p>
                    </div>
                  </td>
                  <td class="px-5 py-4 text-muted"><%= b.seats.join(', ') %></td>
                  <td class="px-5 py-4 font-medium text-white">₹<%= b.amount.toLocaleString('en-IN') %></td>
                  <td class="px-5 py-4">
                    <%
                      const badge = {
                        'Confirmed': 'bg-primary-soft text-primary border-primary/30',
                        'Pending': 'bg-yellow-500/10 text-yellow-400 border-yellow-500/30',
                        'Cancelled': 'bg-white/5 text-muted border-border'
                      }[b.status] || 'bg-primary-soft text-primary border-primary/30';
                    %>
                    <span class="px-2.5 py-1 text-xs font-medium border rounded-full <%= badge %>"><%= b.status %></span>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>
