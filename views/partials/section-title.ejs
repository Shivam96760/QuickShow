<div class="flex items-end justify-between mb-6">
  <div>
    <% if (typeof eyebrow !== 'undefined' && eyebrow) { %>
      <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2"><%= eyebrow %></p>
    <% } %>
    <h2 class="font-display text-2xl sm:text-3xl font-bold text-white tracking-tight"><%= heading %></h2>
    <% if (typeof subheading !== 'undefined' && subheading) { %>
      <p class="mt-2 text-sm text-muted max-w-xl text-pretty"><%= subheading %></p>
    <% } %>
  </div>
  <% if (typeof link !== 'undefined' && link) { %>
    <a href="<%= link.href %>" class="hidden sm:inline-flex items-center gap-1 text-sm text-muted hover:text-white transition-colors">
      <%= link.label %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
    </a>
  <% } %>
</div>
