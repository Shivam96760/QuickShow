<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <a href="javascript:history.back()" class="inline-flex items-center gap-1 text-sm text-muted hover:text-white transition-colors">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
    Back
  </a>
  <h1 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-white tracking-tight">Checkout</h1>
  <p class="mt-1 text-sm text-muted">Review your booking and confirm.</p>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8">
    <!-- Payment form -->
    <div class="space-y-6">
      <div class="bg-card border border-border rounded-2xl p-6">
        <h2 class="font-display text-lg font-semibold text-white mb-4">Contact details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <label class="block">
            <span class="text-xs font-medium text-muted">Full name</span>
            <input type="text" id="checkout-name" value="<%= currentUser ? currentUser.name : '' %>" class="mt-1.5 w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
          </label>
          <label class="block">
            <span class="text-xs font-medium text-muted">Email</span>
            <input type="email" id="checkout-email" value="<%= currentUser ? currentUser.email : '' %>" class="mt-1.5 w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
          </label>
          <label class="block sm:col-span-2">
            <span class="text-xs font-medium text-muted">Phone number</span>
            <input type="tel" placeholder="+91 98765 43210" class="mt-1.5 w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-sm text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
          </label>
        </div>
      </div>


    </div>

    <!-- Summary -->
    <aside class="bg-card border border-border rounded-2xl p-6 h-fit lg:sticky lg:top-24">
      <h2 class="font-display text-lg font-semibold text-white">Order summary</h2>

      <div class="mt-4 flex items-start gap-3">
        <img src="<%= movie.poster %>" alt="" class="w-16 h-24 rounded-lg object-cover border border-border" />
        <div class="min-w-0">
          <p class="font-medium text-white truncate"><%= movie.title %></p>
          <p class="mt-1 text-xs text-muted"><%= showTime %></p>
          <p class="mt-1 text-xs text-muted"><%= movie.runtime %></p>
        </div>
      </div>

      <div class="mt-5 pt-5 border-t border-border space-y-3 text-sm">
        <div class="flex items-start justify-between gap-3">
          <span class="text-muted">Seats (<%= seats.length %>)</span>
          <span class="font-medium text-white text-right"><%= seats.join(', ') %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted">Price per seat</span>
          <span class="font-medium text-white">₹<%= pricePerSeat.toLocaleString('en-IN') %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted">Convenience fee</span>
          <span class="font-medium text-white">₹35</span>
        </div>
      </div>

      <div class="mt-5 pt-5 border-t border-border flex items-end justify-between">
        <span class="text-white">Total</span>
        <span class="font-display text-3xl font-bold text-primary">
          ₹<%= (seats.length * pricePerSeat + 35).toLocaleString('en-IN') %>
        </span>
      </div>

      <button
        type="button"
        id="confirm-booking-btn"
        class="mt-6 w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-primary hover:bg-primary-hover text-white font-medium rounded-xl transition-colors"
      >
        Confirm booking
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
      </button>

      <p class="mt-3 text-xs text-muted text-center">Your booking will be confirmed instantly.</p>
    </aside>
  </div>
</section>

<!-- Booking confirmation modal -->
<div id="booking-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="bg-card border border-border rounded-2xl p-8 max-w-sm w-full text-center shadow-glow">
      <div class="w-16 h-16 mx-auto rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center">
        <svg class="w-8 h-8 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h2 class="mt-4 font-display text-xl font-bold text-white">Booking confirmed!</h2>
      <p id="modal-booking-id" class="mt-2 text-sm text-muted"></p>
      <div class="mt-6 flex flex-col gap-2">
        <a href="/my-bookings" class="px-5 py-3 bg-primary hover:bg-primary-hover text-white font-medium rounded-xl transition-colors">View my bookings</a>
        <a href="/" class="px-5 py-3 text-sm text-muted hover:text-white transition-colors">Back to home</a>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const btn = document.getElementById('confirm-booking-btn')
    const modal = document.getElementById('booking-modal')
    const modalId = document.getElementById('modal-booking-id')

    btn.addEventListener('click', async () => {
      btn.disabled = true
      btn.textContent = 'Processing...'

      try {
        const res = await fetch('/api/bookings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            showId: '<%= showId %>',
            seats: <%- JSON.stringify(seats) %>,
          }),
        })

        const data = await res.json()

        if (res.ok && data.success) {
          modalId.textContent = 'Booking ID: ' + data.bookingId
          modal.classList.remove('hidden')
        } else {
          alert(data.error || 'Booking failed. Please try again.')
          btn.disabled = false
          btn.innerHTML = 'Confirm booking <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>'
        }
      } catch (err) {
        alert('Network error. Please try again.')
        btn.disabled = false
        btn.innerHTML = 'Confirm booking <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>'
      }
    })
  })()
</script>
