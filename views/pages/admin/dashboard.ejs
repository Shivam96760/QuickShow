<div class="lg:flex">
  <%- include('../../partials/admin-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <!-- Admin top bar -->
    <header class="sticky top-0 z-30 bg-background/90 backdrop-blur border-b border-border">
      <div class="flex items-center justify-between px-4 sm:px-8 h-16">
        <div class="flex items-center gap-3">
          <a href="/" class="lg:hidden flex items-center gap-2">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm7 3v10h2V7h-2Z"/></svg>
            </span>
            <span class="font-display font-bold text-white">QuickShow</span>
          </a>
          <h1 class="hidden lg:block font-display text-xl font-semibold text-white">Dashboard</h1>
        </div>
        <div class="flex items-center gap-3">
          <a href="/" class="text-xs text-muted hover:text-white transition-colors">View site</a>
          <div class="w-8 h-8 rounded-full bg-card border border-border flex items-center justify-center text-xs font-semibold text-white">A</div>
        </div>
      </div>
    </header>

    <main class="p-4 sm:p-8">
      <div class="mb-8">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-white">Welcome back, Admin</h2>
        <p class="mt-1 text-sm text-muted">Here's an overview of your cinema.</p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <%
          const cards = [
            { label: 'Total Movies', value: stats.movies, icon: 'film', trend: '+2 this month' },
            { label: 'Total Shows', value: stats.shows, icon: 'calendar', trend: '+12 this week' },
            { label: 'Total Bookings', value: stats.bookings.toLocaleString(), icon: 'ticket', trend: '+124 today' },
            { label: 'Revenue', value: '₹' + stats.revenue.toLocaleString('en-IN'), icon: 'money', trend: '+8.2% vs last month' },
          ];
        %>
        <% cards.forEach(card => { %>
          <div class="bg-card border border-border rounded-2xl p-5 hover:border-primary/40 transition-colors">
            <div class="flex items-start justify-between">
              <div class="w-10 h-10 rounded-lg bg-primary-soft text-primary flex items-center justify-center">
                <% if (card.icon === 'film') { %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="7" y1="3" x2="7" y2="21"/><line x1="17" y1="3" x2="17" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
                <% } else if (card.icon === 'calendar') { %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <% } else if (card.icon === 'ticket') { %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v2a2 2 0 0 0 0 4v2a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3v-2a2 2 0 0 0 0-4V9Z"/></svg>
                <% } else { %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                <% } %>
              </div>
            </div>
            <p class="mt-4 text-xs font-medium uppercase tracking-wider text-muted"><%= card.label %></p>
            <p class="mt-1 font-display text-2xl sm:text-3xl font-bold text-white"><%= card.value %></p>
            <p class="mt-2 text-xs text-primary"><%= card.trend %></p>
          </div>
        <% }); %>
      </div>

      <!-- Active shows -->
      <div class="mt-8 bg-card border border-border rounded-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
          <div>
            <h3 class="font-display text-lg font-semibold text-white">Active shows</h3>
            <p class="text-xs text-muted">Recent bookings across all shows.</p>
          </div>
          <a href="/admin/list-bookings" class="text-xs text-primary hover:underline">View all</a>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs font-medium uppercase tracking-wider text-muted bg-surface/60">
                <th class="px-5 py-3">Booking</th>
                <th class="px-5 py-3">Movie</th>
                <th class="px-5 py-3">Seats</th>
                <th class="px-5 py-3">Amount</th>
                <th class="px-5 py-3">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <% shows.forEach(b => { %>
                <tr class="hover:bg-surface/40 transition-colors">
                  <td class="px-5 py-4 font-mono text-xs text-white"><%= b.id %></td>
                  <td class="px-5 py-4">
                    <div class="flex items-center gap-3 min-w-0">
                      <img src="<%= b.movie.poster %>" alt="" class="w-8 h-10 rounded object-cover border border-border" />
                      <div class="min-w-0">
                        <p class="font-medium text-white truncate"><%= b.movie.title %></p>
                        <p class="text-xs text-muted truncate"><%= b.date %></p>
                      </div>
                    </div>
                  </td>
                  <td class="px-5 py-4 text-muted"><%= b.seats.join(', ') %></td>
                  <td class="px-5 py-4 font-medium text-white">₹<%= b.amount.toLocaleString('en-IN') %></td>
                  <td class="px-5 py-4">
                    <%
                      const badge = {
                        'Confirmed': 'bg-primary-soft text-primary border-primary/30',
                        'Pending': 'bg-yellow-500/10 text-yellow-400 border-yellow-500/30',
                        'Cancelled': 'bg-white/5 text-muted border-border'
                      }[b.status] || 'bg-primary-soft text-primary border-primary/30';
                    %>
                    <span class="px-2.5 py-1 text-xs font-medium border rounded-full <%= badge %>"><%= b.status %></span>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>
