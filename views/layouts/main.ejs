<!DOCTYPE html>
<html lang="en" class="bg-background">
  <head>
    <%- include('../partials/head') %>
  </head>
  <body class="min-h-screen bg-background text-white font-sans antialiased">
    <% if (!isAdmin) { %>
      <%- include('../partials/navbar') %>
    <% } %>

    <main class="<%= isAdmin ? 'min-h-screen' : 'min-h-[calc(100vh-4rem)]' %>">
      <%- body %>
    </main>

    <% if (!isAdmin) { %>
      <%- include('../partials/footer') %>
    <% } %>

    <script src="/js/app.js"></script>
  </body>
</html>
