<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
  <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between gap-4">
    <div>
      <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2">All movies</p>
      <h1 class="font-display text-3xl sm:text-4xl font-bold text-white tracking-tight">Discover what's playing</h1>
      <p class="mt-2 text-sm text-muted max-w-xl">Browse every movie showing in cinemas this week. Filter by genre or search for your favourite.</p>
    </div>

    <div class="flex items-center gap-2">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <input
          type="search"
          placeholder="Search movies..."
          class="pl-9 pr-4 py-2.5 w-full sm:w-64 bg-card border border-border rounded-xl text-sm text-white placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
        />
      </div>
      <button class="hidden sm:inline-flex items-center gap-2 px-4 py-2.5 bg-card border border-border rounded-xl text-sm text-white hover:border-primary/60 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
        Filters
      </button>
    </div>
  </div>

  <!-- Genre chips -->
  <div class="mt-6 flex items-center gap-2 overflow-x-auto no-scrollbar pb-2">
    <% const chips = ['All', 'Action', 'Drama', 'Sci-Fi', 'Animation', 'Thriller', 'Adventure', 'Crime']; %>
    <% chips.forEach((chip, i) => { %>
      <button class="px-4 py-2 rounded-full text-sm whitespace-nowrap border transition-colors <%= i === 0 ? 'bg-primary border-primary text-white' : 'bg-card border-border text-muted hover:text-white hover:border-primary/50' %>">
        <%= chip %>
      </button>
    <% }); %>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6">
    <% movies.forEach(movie => { %>
      <%- include('../partials/movie-card', { movie }) %>
    <% }); %>
  </div>
</section>
