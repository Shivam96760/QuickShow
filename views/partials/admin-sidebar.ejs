<aside class="lg:fixed lg:inset-y-0 lg:left-0 lg:w-64 lg:border-r lg:border-border lg:bg-surface">
  <div class="h-full flex lg:flex-col">
    <div class="hidden lg:flex items-center gap-2 h-16 px-6 border-b border-border">
      <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm7 3v10h2V7h-2Z"/></svg>
      </span>
      <div>
        <p class="font-display font-bold text-white leading-tight">QuickShow</p>
        <p class="text-xs text-muted leading-tight">Admin panel</p>
      </div>
    </div>

    <nav class="flex lg:flex-col gap-1 p-3 lg:p-4 overflow-x-auto lg:overflow-visible w-full">
      <% const adminLinks = [
        { href: '/admin', label: 'Dashboard', icon: 'dashboard' },
        { href: '/admin/add-shows', label: 'Add Shows', icon: 'plus' },
        { href: '/admin/list-shows', label: 'List Shows', icon: 'list' },
        { href: '/admin/list-bookings', label: 'List Bookings', icon: 'ticket' },
      ]; %>

      <% adminLinks.forEach(link => { %>
        <a
          href="<%= link.href %>"
          class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors whitespace-nowrap <%= currentPath === link.href ? 'bg-primary-soft text-primary font-medium' : 'text-muted hover:text-white hover:bg-card' %>"
        >
          <% if (link.icon === 'dashboard') { %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
          <% } else if (link.icon === 'plus') { %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <% } else if (link.icon === 'list') { %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="3.5" cy="6" r="1"/><circle cx="3.5" cy="12" r="1"/><circle cx="3.5" cy="18" r="1"/></svg>
          <% } else { %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v2a2 2 0 0 0 0 4v2a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3v-2a2 2 0 0 0 0-4V9Z"/><line x1="13" y1="5" x2="13" y2="7"/><line x1="13" y1="11" x2="13" y2="13"/><line x1="13" y1="17" x2="13" y2="19"/></svg>
          <% } %>
          <span><%= link.label %></span>
        </a>
      <% }); %>
    </nav>

    <div class="hidden lg:block mt-auto p-4 border-t border-border">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-card border border-border flex items-center justify-center text-sm font-semibold text-white">A</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white truncate">Admin User</p>
          <p class="text-xs text-muted truncate">admin@quickshow.com</p>
        </div>
      </div>
    </div>
  </div>
</aside>
