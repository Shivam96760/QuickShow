<header class="sticky top-0 z-40 backdrop-blur-md bg-background/80 border-b border-border">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 group">
      <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-primary shadow-glow">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2 3v2h2V7H6Zm10 0v2h2V7h-2ZM6 11v2h2v-2H6Zm10 0v2h2v-2h-2ZM6 15v2h2v-2H6Zm10 0v2h2v-2h-2Zm-5-8v10h2V7h-2Z"/>
        </svg>
      </span>
      <span class="font-display font-bold text-xl tracking-tight text-white">
        Quick<span class="text-primary">Show</span>
      </span>
    </a>

    <ul class="hidden md:flex items-center gap-1 text-sm">
      <% const links = [
        { href: '/', label: 'Home' },
        { href: '/movies', label: 'Movies' },
        { href: '/my-bookings', label: 'My Bookings' },
        { href: '/favorites', label: 'Favorites' },
      ]; %>
      <% links.forEach(link => { %>
        <li>
          <a
            href="<%= link.href %>"
            class="px-4 py-2 rounded-lg transition-colors <%= currentPath === link.href ? 'text-white bg-card' : 'text-muted hover:text-white hover:bg-card/60' %>"
          >
            <%= link.label %>
          </a>
        </li>
      <% }); %>
    </ul>

    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Search"
        class="hidden sm:flex items-center justify-center w-10 h-10 rounded-lg text-muted hover:text-white hover:bg-card transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>

      <% if (currentUser && currentUser.role === 'admin') { %>
        <a
          href="/admin"
          class="hidden sm:inline-flex items-center px-3 py-2 text-xs font-medium text-primary border border-primary/30 rounded-lg transition-colors hover:bg-primary-soft"
        >
          Admin
        </a>
      <% } %>

      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open menu"
        class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white hover:bg-card"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <% if (currentUser) { %>
        <div class="hidden sm:flex items-center gap-2">
          <div class="flex items-center justify-center w-9 h-9 rounded-full bg-primary-soft border border-primary/30">
            <span class="text-sm font-semibold text-primary"><%= currentUser.name.charAt(0).toUpperCase() %></span>
          </div>
          <div class="hidden lg:block">
            <p class="text-xs font-medium text-white leading-tight"><%= currentUser.name %></p>
            <p class="text-[10px] text-muted leading-tight"><%= currentUser.email %></p>
          </div>
          <a href="/logout" class="ml-1 px-3 py-2 text-xs text-muted hover:text-white border border-border rounded-lg transition-colors">
            Logout
          </a>
        </div>
      <% } else { %>
        <a
          href="/login"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-medium rounded-lg transition-colors"
        >
          Sign in
        </a>
      <% } %>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-background">
    <div class="px-4 py-3 flex flex-col gap-1">
      <a href="/" class="px-3 py-2 rounded-lg text-sm text-white hover:bg-card">Home</a>
      <a href="/movies" class="px-3 py-2 rounded-lg text-sm text-white hover:bg-card">Movies</a>
      <a href="/my-bookings" class="px-3 py-2 rounded-lg text-sm text-white hover:bg-card">My Bookings</a>
      <a href="/favorites" class="px-3 py-2 rounded-lg text-sm text-white hover:bg-card">Favorites</a>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/admin" class="px-3 py-2 rounded-lg text-sm text-primary hover:bg-card">Admin Panel</a>
      <% } %>
      <% if (currentUser) { %>
        <div class="mt-2 px-3 py-2 flex items-center gap-2 text-sm text-muted">
          <span class="text-white font-medium"><%= currentUser.name %></span>
        </div>
        <a href="/logout" class="px-3 py-2 rounded-lg text-sm text-red-400 hover:bg-card">Logout</a>
      <% } else { %>
        <a href="/login" class="mt-2 px-3 py-2 bg-primary hover:bg-primary-hover text-white text-sm font-medium rounded-lg text-center">Sign in</a>
      <% } %>
    </div>
  </div>
</header>

<script>
  (function () {
    const btn = document.getElementById('mobile-menu-btn')
    const menu = document.getElementById('mobile-menu')
    if (btn && menu) {
      btn.addEventListener('click', () => menu.classList.toggle('hidden'))
    }
  })()
</script>
