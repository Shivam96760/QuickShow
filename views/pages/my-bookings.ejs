<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8">
    <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2">Your bookings</p>
    <h1 class="font-display text-3xl sm:text-4xl font-bold text-white tracking-tight">My bookings</h1>
    <p class="mt-1 text-sm text-muted">All your past and upcoming reservations in one place.</p>
  </div>

  <% if (bookings.length === 0) { %>
    <div class="bg-card border border-border rounded-2xl p-12 text-center">
      <div class="w-16 h-16 mx-auto rounded-full bg-primary-soft flex items-center justify-center">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 3-3h14a3 3 0 0 1 3 3v2a2 2 0 0 0 0 4v2a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3v-2a2 2 0 0 0 0-4V9Z"/></svg>
      </div>
      <p class="mt-4 text-lg text-white">You haven't booked anything yet.</p>
      <a href="/movies" class="mt-4 inline-flex items-center gap-2 px-5 py-2.5 bg-primary hover:bg-primary-hover text-white text-sm font-medium rounded-xl transition-colors">
        Browse movies
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14m-6-6 6 6-6 6"/></svg>
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% bookings.forEach(booking => { %>
        <article class="booking-card bg-card border border-border rounded-2xl p-4 sm:p-6 flex flex-col sm:flex-row gap-4 sm:gap-6 hover:border-primary/40 transition-colors" data-booking-id="<%= booking.id %>">
          <img src="<%= booking.movie.poster %>" alt="" class="w-full sm:w-28 h-40 sm:h-40 rounded-xl object-cover border border-border" />

          <div class="flex-1 min-w-0 flex flex-col">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <h3 class="font-display text-lg font-semibold text-white truncate"><%= booking.movie.title %></h3>
                <p class="mt-1 text-xs text-muted"><%= booking.movie.genres.join(' · ') %> · <%= booking.movie.runtime %></p>
              </div>
              <%
                const badge = {
                  'Confirmed': 'bg-primary-soft text-primary border-primary/30',
                  'Pending': 'bg-yellow-500/10 text-yellow-400 border-yellow-500/30',
                  'Cancelled': 'bg-white/5 text-muted border-border'
                }[booking.status] || 'bg-primary-soft text-primary border-primary/30';
              %>
              <span class="booking-status px-2.5 py-1 text-xs font-medium border rounded-full whitespace-nowrap <%= badge %>">
                <%= booking.status %>
              </span>
            </div>

            <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
              <div>
                <p class="text-xs text-muted">Date & time</p>
                <p class="mt-0.5 font-medium text-white"><%= booking.date %></p>
              </div>
              <div>
                <p class="text-xs text-muted">Seats</p>
                <p class="mt-0.5 font-medium text-white"><%= booking.seats.join(', ') %></p>
              </div>
              <div>
                <p class="text-xs text-muted">Booking ID</p>
                <p class="mt-0.5 font-medium text-white"><%= booking.id %></p>
              </div>
              <div>
                <p class="text-xs text-muted">Amount</p>
                <p class="mt-0.5 font-display text-lg font-bold text-primary">₹<%= booking.amount.toLocaleString('en-IN') %></p>
              </div>
            </div>

            <div class="mt-4 flex items-center gap-3">
              <% if (booking.status === 'Confirmed') { %>
                <button
                  class="cancel-booking-btn px-4 py-2 text-xs font-medium text-red-400 border border-red-500/30 rounded-lg hover:bg-red-500/10 transition-colors"
                  data-booking-id="<%= booking.id %>"
                >
                  Cancel booking
                </button>
              <% } %>
              <% if (booking.status === 'Cancelled') { %>
                <span class="px-4 py-2 text-xs text-muted">This booking was cancelled</span>
              <% } %>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  <% } %>
</section>

<script>
  (function () {
    document.querySelectorAll('.cancel-booking-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const bookingId = btn.dataset.bookingId
        if (!confirm('Are you sure you want to cancel this booking?')) return

        btn.disabled = true
        btn.textContent = 'Cancelling...'

        try {
          const res = await fetch('/api/bookings/' + bookingId + '/cancel', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
          })

          const data = await res.json()

          if (res.ok && data.success) {
            // Update the UI
            const card = btn.closest('.booking-card')
            const statusBadge = card.querySelector('.booking-status')
            statusBadge.className = 'booking-status px-2.5 py-1 text-xs font-medium border rounded-full whitespace-nowrap bg-white/5 text-muted border-border'
            statusBadge.textContent = 'Cancelled'
            btn.replaceWith(Object.assign(document.createElement('span'), {
              className: 'px-4 py-2 text-xs text-muted',
              textContent: 'This booking was cancelled'
            }))
          } else {
            alert(data.error || 'Failed to cancel. Try again.')
            btn.disabled = false
            btn.textContent = 'Cancel booking'
          }
        } catch (err) {
          alert('Network error. Try again.')
          btn.disabled = false
          btn.textContent = 'Cancel booking'
        }
      })
    })
  })()
</script>
