<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8">
    <a href="/movies/<%= movie.id %>" class="inline-flex items-center gap-1 text-sm text-muted hover:text-white transition-colors">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      Back to movie
    </a>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-white tracking-tight">Select your seats</h1>
    <p class="mt-1 text-sm text-muted"><%= movie.title %> · <%= showTime %></p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8">
    <!-- Seat map -->
    <div class="bg-card border border-border rounded-2xl p-6 sm:p-8">
      <!-- Screen -->
      <div class="mb-10">
        <div class="screen"></div>
        <p class="text-center text-xs uppercase tracking-widest text-muted mt-3">Screen this way</p>
      </div>

      <!-- Grid -->
      <div class="flex justify-center">
        <div class="inline-block">
          <%
            const rows = ['A','B','C','D','E','F','G','H','I','J'];
            const cols = 9;
          %>
          <% rows.forEach(row => { %>
            <div class="flex items-center gap-1.5 mb-1.5 justify-center">
              <span class="w-5 text-center text-xs font-medium text-muted"><%= row %></span>
              <% for (let c = 1; c <= cols; c++) {
                const seatId = row + c;
                const isOccupied = occupied.includes(seatId);
              %>
                <% if (c === 5) { %><span class="w-4"></span><% } %>
                <button
                  type="button"
                  class="seat <%= isOccupied ? 'occupied' : '' %>"
                  data-seat="<%= seatId %>"
                  <%= isOccupied ? 'disabled aria-disabled="true"' : '' %>
                  aria-label="Seat <%= seatId %>"
                >
                  <%= c %>
                </button>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Legend -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-xs text-muted">
        <div class="seat-legend">
          <span class="seat-legend-box" style="background:#1f1f24;border-color:#2e2e34;"></span>
          Available
        </div>
        <div class="seat-legend">
          <span class="seat-legend-box" style="background:#F84565;border-color:#F84565;"></span>
          Selected
        </div>
        <div class="seat-legend">
          <span class="seat-legend-box" style="background:#0e0e10;border-color:#1a1a1e;"></span>
          Occupied
        </div>
      </div>
    </div>

    <!-- Summary -->
    <aside class="bg-card border border-border rounded-2xl p-6 h-fit lg:sticky lg:top-24">
      <h2 class="font-display text-lg font-semibold text-white">Booking summary</h2>
      <div class="mt-4 flex items-start gap-3">
        <img src="<%= movie.poster %>" alt="" class="w-16 h-24 rounded-lg object-cover border border-border" />
        <div class="min-w-0">
          <p class="font-medium text-white truncate"><%= movie.title %></p>
          <p class="mt-1 text-xs text-muted"><%= showTime %></p>
          <p class="mt-1 text-xs text-muted"><%= movie.runtime %> · <%= movie.genres[0] %></p>
        </div>
      </div>

      <div class="mt-6 space-y-3 text-sm">
        <div class="flex items-center justify-between">
          <span class="text-muted">Seats</span>
          <span id="summary-seats" class="font-medium text-white">None</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-muted">Price per seat</span>
          <span class="font-medium text-white">₹<%= pricePerSeat %></span>
        </div>
        <div class="border-t border-border pt-3 flex items-center justify-between">
          <span class="text-white">Total</span>
          <span id="summary-total" class="font-display text-2xl font-bold text-primary">₹0</span>
        </div>
      </div>

      <p class="mt-4 text-xs text-muted">You can select up to 5 seats per booking.</p>

      <a
        id="proceed-btn"
        href="#"
        class="mt-6 w-full inline-flex items-center justify-center gap-2 px-5 py-3 bg-primary hover:bg-primary-hover text-white font-medium rounded-xl transition-colors opacity-50 pointer-events-none"
      >
        Proceed to checkout
      </a>
    </aside>
  </div>
</section>

<script>
  (function () {
    const MAX_SEATS = 5
    const PRICE = <%= pricePerSeat %>
    const SHOW_ID = '<%= showId %>'
    const seats = document.querySelectorAll('.seat:not([disabled])')
    const summarySeats = document.getElementById('summary-seats')
    const summaryTotal = document.getElementById('summary-total')
    const proceed = document.getElementById('proceed-btn')
    const selected = new Set()

    function update() {
      const list = Array.from(selected).sort()
      summarySeats.textContent = list.length ? list.join(', ') : 'None'
      summaryTotal.textContent = '₹' + (list.length * PRICE).toLocaleString('en-IN')
      if (list.length > 0) {
        proceed.classList.remove('opacity-50', 'pointer-events-none')
        proceed.href = '/checkout?showId=' + SHOW_ID + '&seats=' + list.join(',')
      } else {
        proceed.classList.add('opacity-50', 'pointer-events-none')
        proceed.href = '#'
      }
    }

    seats.forEach((seat) => {
      seat.addEventListener('click', () => {
        const id = seat.dataset.seat
        if (selected.has(id)) {
          selected.delete(id)
          seat.classList.remove('selected')
        } else {
          if (selected.size >= MAX_SEATS) {
            seat.animate([{ transform: 'translateX(-4px)' }, { transform: 'translateX(4px)' }, { transform: 'translateX(0)' }], { duration: 200 })
            return
          }
          selected.add(id)
          seat.classList.add('selected')
        }
        update()
      })
    })

    update()
  })()
</script>
